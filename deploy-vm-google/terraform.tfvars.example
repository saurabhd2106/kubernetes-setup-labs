project_id   = "my-gcp-project"
region       = "us-central1"
zone         = "us-central1-a"
name_prefix  = "demo"
vm_count     = 3
machine_type = "e2-medium"
image        = "debian-cloud/debian-12"
disk_size_gb = 20
subnet_cidr  = "10.10.0.0/24"

assign_public_ip  = true
ssh_source_ranges = ["0.0.0.0/0"]

# SSH key options
# 1) Auto-generate (default): leave ssh_public_key empty.
#    Terraform will create ./<name_prefix>-key.pem and use ssh_user below.
ssh_user = "ubuntu"

# 2) Use your own existing key: paste the public key contents here.
# ssh_public_key = "ssh-rsa AAAA... user@host"

tags = ["demo"]

labels = {
  env     = "dev"
  managed = "terraform"
}
