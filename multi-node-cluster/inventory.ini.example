# =====================================================================
# inventory.ini.example - Address book for the multi-node Kubernetes
#                         cluster.
#
# 1. Copy this file:    cp inventory.ini.example inventory.ini
# 2. Replace the IP addresses below with the *internal* IPs of the VMs
#    that Terraform created. You can grab them with:
#        cd ../deploy-vm-google && terraform output -json vm_internal_ips
# 3. Update the SSH key path if you supplied your own key to Terraform.
#
# All hosts must be reachable from the Ansible controller and from each
# other on the VPC private network.
# =====================================================================

# ---- Control-plane node (exactly ONE host) --------------------------
[masters]
master ansible_host=10.10.0.2

# ---- Worker nodes (ONE OR MORE hosts) -------------------------------
# Add or remove lines here to grow or shrink the cluster.
[workers]
worker-1 ansible_host=10.10.0.3
worker-2 ansible_host=10.10.0.4

# ---- Logical parent group: every Kubernetes node --------------------
[k8s_cluster:children]
masters
workers

# ---- Connection settings shared by every node -----------------------
[k8s_cluster:vars]
ansible_user=ubuntu
ansible_ssh_private_key_file=../deploy-vm-google/demo-key.pem
ansible_ssh_common_args='-o StrictHostKeyChecking=accept-new -o UserKnownHostsFile=/dev/null'
ansible_python_interpreter=/usr/bin/python3
